# Langfuse additional configuration
# These supplement the values in the root .env file.
# Copy this to langfuse.env and fill in production values.

# Telemetry — disable to keep all data local
TELEMETRY_ENABLED=false

# Sign-up — disable after creating your account
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=false

# Default org/project created on first start
LANGFUSE_DEFAULT_ORG_NAME=rig-stack
LANGFUSE_DEFAULT_ORG_ID=rig-stack-local

# SMTP (optional — only needed for email invites/password reset)
# SMTP_CONNECTION_URL=smtp://user:pass@host:587
# EMAIL_FROM_ADDRESS=rig-stack@localhost
