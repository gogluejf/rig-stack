#!/usr/bin/env bash
# rig — rig-stack CLI
#
# Your RTX 5090 server as a private cloud. One command away.
#
# Installed to /usr/local/bin/rig by scripts/setup/05-install-cli.sh
# Source: cli/ in the rig-stack repository

set -euo pipefail

# ── Find repo root ─────────────────────────────────────────────────────────────
# Follows the symlink back to the actual cli/ directory.
SELF="$(readlink -f "${BASH_SOURCE[0]}")"
CLI_DIR="$(dirname "${SELF}")"
export RIG_ROOT="$(dirname "${CLI_DIR}")"

# ── Load env and libs ─────────────────────────────────────────────────────────
source "${CLI_DIR}/lib/utils.sh"
source "${CLI_DIR}/lib/infra.sh"
source "${CLI_DIR}/lib/vllm.sh"
source "${CLI_DIR}/lib/comfy.sh"
source "${CLI_DIR}/lib/ollama.sh"
source "${CLI_DIR}/lib/rag.sh"
source "${CLI_DIR}/lib/models.sh"
source "${CLI_DIR}/lib/status.sh"
source "${CLI_DIR}/lib/stats.sh"

load_env

# ── Help ──────────────────────────────────────────────────────────────────────
_help_cmd_row() {
    local main_display="$1"
    local main_raw="$2"
    local sub_display="$3"
    local sub_raw="$4"
    local description="$5"
    local main_pad=$((12 - ${#main_raw}))
    local sub_pad=$((28 - ${#sub_raw}))

    (( main_pad < 0 )) && main_pad=0
    (( sub_pad < 1 )) && sub_pad=1

    printf "  %b" "${main_display}"
    printf "%*s" "${main_pad}" ""
    printf "  %b" "${sub_display}"
    printf "%*s" "${sub_pad}" ""
    echo -e "${DIM}${description}${RESET}"
}

print_help() {
    echo ""
    echo -e "\n  ${BOLD}rig — rig-stack control plane${RESET}"
    echo -e "  ${DIM}RTX 5090 · Ubuntu 24.04 · Your private AI cloud${RESET}"
    echo ""
    echo -e "  ${GREEN}${BOLD}USAGE${RESET}"
    echo -e "    ${BOLD}rig${RESET} ${CYAN}<command>${RESET} ${CYAN}[subcommand]${RESET} ${YELLOW_SOFT}[flags]${RESET}"
    echo ""
    echo -e "  ${GREEN}${BOLD}COMMANDS${RESET}"
    echo ""
    _help_cmd_row "${BOLD}serve${RESET}" "serve" "${CYAN}[<preset>]${RESET} ${YELLOW_SOFT}[--edge]${RESET}" "[<preset>] [--edge]" "start vLLM in stable or edge GPU mode"
    _help_cmd_row "" "" "${DIM}stop${RESET}" "stop" "stop vLLM"
    _help_cmd_row "" "" "${DIM}preset set${RESET} ${CYAN}<name>${RESET}" "preset set <name>" "set active preset (no start)"
    _help_cmd_row "" "" "${DIM}preset list${RESET}" "preset list" "list available presets"
    _help_cmd_row "" "" "${DIM}preset show${RESET} ${CYAN}[<name>]${RESET}" "preset show [<name>]" "show preset config"
    echo ""
    _help_cmd_row "${BOLD}comfy${RESET}" "comfy" "${DIM}start${RESET} ${YELLOW_SOFT}[--cpu|--edge]${RESET}" "start [--cpu|--edge]" "start ComfyUI in CPU, stable GPU, or edge GPU mode"
    _help_cmd_row "" "" "${DIM}stop${RESET}" "stop" "stop ComfyUI"
    _help_cmd_row "" "" "${DIM}list${RESET}" "list" "list installed Comfy models"
    _help_cmd_row "" "" "${DIM}workflows${RESET}" "workflows" "list saved workflow files"
    echo ""
    _help_cmd_row "${BOLD}ollama${RESET}" "ollama" "${DIM}start${RESET} ${YELLOW_SOFT}[--gpu]${RESET}" "start [--gpu]" "start Ollama (--gpu for GPU mode)"
    _help_cmd_row "" "" "${DIM}stop${RESET}" "stop" "stop Ollama"
    _help_cmd_row "" "" "${DIM}list${RESET}" "list" "list installed Ollama models"
    echo ""
    _help_cmd_row "${BOLD}rag${RESET}" "rag" "${DIM}start${RESET}" "start" "start RAG API + Qdrant"
    _help_cmd_row "" "" "${DIM}stop${RESET}" "stop" "stop RAG stack"
    echo ""
    _help_cmd_row "${BOLD}models${RESET}" "models" "${DIM}list${RESET}" "list" "list all installed models"
    _help_cmd_row "" "" "${DIM}init${RESET} ${YELLOW_SOFT}[--all|--minimal]${RESET}" "init [--all|--minimal]" "install a curated model bundle"
    _help_cmd_row "" "" "${DIM}install${RESET} ${CYAN}<source>${RESET}" "install <source>" "install one model from HuggingFace, Ollama, or ComfyUI Manager"
    _help_cmd_row "" "" "${DIM}show${RESET} ${CYAN}<source>${RESET}" "show <source>" "show one model (use --type for Ollama or ComfyUI)"
    _help_cmd_row "" "" "${DIM}remove${RESET} ${CYAN}<source>${RESET}" "remove <source>" "remove one model (use --type for Ollama or ComfyUI)"
    echo ""
    _help_cmd_row "${BOLD}infra${RESET}" "infra" "${DIM}status${RESET}" "status" "show infrastructure services (hf, qdrant, langfuse, traefik)"
    _help_cmd_row "" "" "${DIM}start${RESET} ${CYAN}<service|all>${RESET}" "start <service|all>" "start an infrastructure service"
    _help_cmd_row "" "" "${DIM}stop${RESET} ${CYAN}<service|all>${RESET}" "stop <service|all>" "stop an infrastructure service"
    echo ""
    _help_cmd_row "${BOLD}status${RESET}" "status" "" "" "active services, models, memory, routes, endpoints"
    _help_cmd_row "${BOLD}stats${RESET}" "stats" "" "" "GPU VRAM, watt, temp, tokens/sec"
    echo ""
    echo -e "  ${GREEN}${BOLD}FLAGS${RESET}"
    echo -e "    ${YELLOW_SOFT}--help${RESET}, ${YELLOW_SOFT}-h${RESET}   ${DIM}show help for any command${RESET}"
    echo ""
    echo -e "  ${GREEN}${BOLD}EXAMPLES${RESET}"
    echo -e "    rig serve ${DIM}qwen3-5-27b${RESET}"
    echo -e "    rig serve ${DIM}qwen3-5-27b-fast${RESET} ${YELLOW_SOFT}--edge${RESET}"
    echo -e "    rig serve preset set ${DIM}qwen3-5-27b-fast${RESET}"
    echo -e "    rig serve preset list"
    echo -e "    rig serve preset show"
    echo -e "    rig comfy start ${YELLOW_SOFT}--cpu${RESET}"
    echo -e "    rig comfy start ${YELLOW_SOFT}--edge${RESET}"
    echo -e "    rig comfy workflows"
    echo -e "    rig ollama start"
    echo -e "    rig infra status"
    echo -e "    rig infra start ${DIM}hf${RESET}"
    echo -e "    rig models init ${YELLOW_SOFT}--minimal${RESET}"
    echo -e "    rig models install ${DIM}Kbenkhaled/Qwen3.5-27B-NVFP4${RESET}"
    echo -e "    rig models install ${DIM}TencentARC/GFPGAN${RESET} ${YELLOW_SOFT}--file${RESET} ${DIM}GFPGANv1.4.pth${RESET}"
    echo -e "    rig models show ${DIM}Kbenkhaled/Qwen3.5-27B-NVFP4${RESET}"
    echo -e "    rig status"
    echo -e "    rig stats"
    echo ""
}

# ── Dispatch ──────────────────────────────────────────────────────────────────
COMMAND="${1:-}"
[[ -n "${COMMAND}" ]] && shift || true

case "${COMMAND}" in
    serve)      cmd_serve "$@" ;;
    comfy)      cmd_comfy "$@" ;;
    ollama)     cmd_ollama "$@" ;;
    rag)        cmd_rag "$@" ;;
    models)     cmd_models "$@" ;;
    infra)      cmd_infra "$@" ;;
    status)     cmd_status "$@" ;;
    stats)      cmd_stats "$@" ;;
    --help|-h|help|"")  print_help ;;
    *)
        echo -e "${RED}Unknown command: ${COMMAND}${RESET}"
        echo "Run 'rig --help' for usage."
        exit 1
        ;;
esac
