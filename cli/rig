#!/usr/bin/env bash
# rig — rig-stack CLI
#
# Your RTX 5090 server as a private cloud. One command away.
#
# Installed to /usr/local/bin/rig by scripts/setup/05-install-cli.sh
# Source: cli/ in the rig-stack repository

set -euo pipefail

# ── Find repo root ─────────────────────────────────────────────────────────────
# Follows the symlink back to the actual cli/ directory.
SELF="$(readlink -f "${BASH_SOURCE[0]}")"
CLI_DIR="$(dirname "${SELF}")"
export RIG_ROOT="$(dirname "${CLI_DIR}")"

# ── Load env and libs ─────────────────────────────────────────────────────────
source "${CLI_DIR}/lib/utils.sh"
source "${CLI_DIR}/lib/service.sh"
source "${CLI_DIR}/lib/vllm.sh"
source "${CLI_DIR}/lib/comfy.sh"
source "${CLI_DIR}/lib/ollama.sh"
source "${CLI_DIR}/lib/rag.sh"
source "${CLI_DIR}/lib/models.sh"
source "${CLI_DIR}/lib/status.sh"
source "${CLI_DIR}/lib/stats.sh"

load_env

# ── Help ──────────────────────────────────────────────────────────────────────
print_help() {
    echo ""
    echo -e "  ${BOLD}${CYAN}rig${RESET} — rig-stack control plane"
    echo -e "  ${DIM}RTX 5090 · Ubuntu 24.04 · Your private AI cloud${RESET}"
    echo ""
    echo -e "  ${BOLD}USAGE${RESET}"
    echo -e "    rig <command> [subcommand] [flags]"
    echo ""
    echo -e "  ${BOLD}COMMANDS${RESET}"
    echo ""
    printf "  ${CYAN}%-12s${RESET}  %-22s  %s\n" "serve" "[<preset>] [--edge]" "Start vLLM in stable or edge GPU mode"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "stop" "Stop vLLM"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "list" "Show available presets"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "preset set <name>" "Set active preset (no start)"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "preset show [<name>]" "Show preset config"
    echo ""
    printf "  ${CYAN}%-12s${RESET}  %-22s  %s\n" "comfy" "start [--cpu|--edge]" "Start ComfyUI in CPU, stable GPU, or edge GPU mode"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "stop" "Stop ComfyUI"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "workflows" "List saved workflow files"
    echo ""
    printf "  ${CYAN}%-12s${RESET}  %-22s  %s\n" "ollama" "start [--gpu]" "Start Ollama (--gpu for GPU mode)"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "stop" "Stop Ollama"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "list" "List installed Ollama models"
    echo ""
    printf "  ${CYAN}%-12s${RESET}  %-22s  %s\n" "rag" "start" "Start RAG API + Qdrant"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "stop" "Stop RAG stack"
    echo ""
    printf "  ${CYAN}%-12s${RESET}  %-22s  %s\n" "models" "" "List installed models"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "init [--all|--minimal]" "Install a curated model bundle"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "install <source>" "Install one model from HuggingFace, Ollama, or ComfyUI Manager"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "show <source>" "Show one model (use --type for Ollama or ComfyUI)"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "remove <source>" "Remove one model (use --type for Ollama or ComfyUI)"
    echo ""
    printf "  ${CYAN}%-12s${RESET}  %-22s  %s\n" "service" "status" "Show infrastructure services (hf, qdrant, langfuse, traefik)"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "start <service|all>" "Start an infrastructure service"
    printf "  ${DIM}%-12s  %-22s  %s${RESET}\n" "" "stop  <service|all>" "Stop an infrastructure service"
    echo ""
    printf "  ${CYAN}%-12s${RESET}  %-22s  %s\n" "status" "" "Active services, models, memory, routes, endpoints"
    printf "  ${CYAN}%-12s${RESET}  %-22s  %s\n" "stats" "" "GPU VRAM, watt, temp, tokens/sec"
    echo ""
    echo -e "  ${BOLD}FLAGS${RESET}"
    echo -e "    --help, -h   Show help for any command"
    echo ""
    echo -e "  ${BOLD}EXAMPLES${RESET}"
    echo -e "    rig serve qwen3-5-27b"
    echo -e "    rig serve qwen3-5-27b-fast --edge"
    echo -e "    rig serve list"
    echo -e "    rig serve preset set qwen3-5-27b-fast"
    echo -e "    rig serve preset show"
    echo -e "    rig comfy start --cpu"
    echo -e "    rig comfy start --edge"
    echo -e "    rig comfy workflows"
    echo -e "    rig ollama start"
    echo -e "    rig service status"
    echo -e "    rig service start hf"
    echo -e "    rig models init --minimal"
    echo -e "    rig models install Kbenkhaled/Qwen3.5-27B-NVFP4"
    echo -e "    rig models install TencentARC/GFPGAN --file GFPGANv1.4.pth"
    echo -e "    rig models show Kbenkhaled/Qwen3.5-27B-NVFP4"
    echo -e "    rig status"
    echo -e "    rig stats"
    echo ""
}

# ── Dispatch ──────────────────────────────────────────────────────────────────
COMMAND="${1:-}"
[[ -n "${COMMAND}" ]] && shift || true

case "${COMMAND}" in
    serve)      cmd_serve "$@" ;;
    comfy)      cmd_comfy "$@" ;;
    ollama)     cmd_ollama "$@" ;;
    rag)        cmd_rag "$@" ;;
    models)     cmd_models "$@" ;;
    service)    cmd_service "$@" ;;
    status)     cmd_status "$@" ;;
    stats)      cmd_stats "$@" ;;
    --help|-h|help|"")  print_help ;;
    *)
        echo -e "${RED}Unknown command: ${COMMAND}${RESET}"
        echo "Run 'rig --help' for usage."
        exit 1
        ;;
esac
