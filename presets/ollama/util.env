# Preset: ollama/util
# Model:  phi3-mini (default utility model)
# Use:    Fast summarization, classification, routing.
#         CPU-only by default — leaves GPU for vLLM / ComfyUI.
#         Override OLLAMA_MODEL with any model from: rig models --ollama

OLLAMA_MODEL=phi3-mini
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_THREAD=8
