# Preset: qwen3-5-27b-low — reduced VRAM footprint
# Model:  Kbenkhaled/Qwen3.5-27B-NVFP4 (fp4 quantized)
# Use:    Run vLLM alongside ComfyUI or other GPU workloads.
#         Lower GPU_MEMORY_UTILIZATION leaves headroom for concurrent tasks.

MODEL_ID=Kbenkhaled/Qwen3.5-27B-NVFP4
MODEL_PATH=/models/llm/qwen3-5-27b
MAX_MODEL_LEN=32768
KV_CACHE_DTYPE=fp8
ENABLE_PREFIX_CACHING=true
TOOL_CALL_PARSER=qwen3_coder
GPU_MEMORY_UTILIZATION=0.55
TENSOR_PARALLEL_SIZE=1
DTYPE=auto
TRUST_REMOTE_CODE=true
