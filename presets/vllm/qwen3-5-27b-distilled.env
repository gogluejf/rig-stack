# Preset: qwen3-5-27b-distilled — distilled v2 variant
# Model:  qwen3-5-27b-open-4-6-distilled-v2 (fp4)
# Use:    Faster inference with distillation. Good throughput for batch workloads.
#         Slightly less reasoning depth than the full model — ideal for agentic pipelines.
#
# Verify exact HuggingFace repo ID before installing:

MODEL_ID=qwen3-5-27b-open-4-6-distilled-v2
MODEL_PATH=/models/llm/qwen3-5-27b-distilled
MAX_MODEL_LEN=65536
KV_CACHE_DTYPE=fp8
ENABLE_PREFIX_CACHING=true
TOOL_CALL_PARSER=qwen3_coder
GPU_MEMORY_UTILIZATION=0.82
TENSOR_PARALLEL_SIZE=1
DTYPE=auto
TRUST_REMOTE_CODE=true
