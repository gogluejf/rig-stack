# Preset: flux2-fp8 — FLUX.2 fp8 quantized (default diffusion preset)
# Model:  FLUX.2-dev fp8 quantized
# HF:     Kijai/flux2-dev-fp8  OR  Unsloth/FLUX.2-dev-fp8  (verify slug before pull)
#         https://huggingface.co/black-forest-labs
# Use:    High-quality FLUX.2 generation at ~50% VRAM vs bf16. Minimal quality loss.
# Note:   HF_TOKEN required — accept license at the model page before downloading.

COMFYUI_MODEL=flux2-dev-fp8.safetensors
COMFYUI_MODEL_PATH=/models/diffusion/flux2-fp8
COMFYUI_EXTRA_MODEL_PATHS=/models/diffusion/flux-lora:/models/upscalers
COMFYUI_PREVIEW_METHOD=auto
COMFYUI_LISTEN=0.0.0.0
COMFYUI_PORT=8188
