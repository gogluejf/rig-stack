# Preset: facefusion — face swap and fusion
# Model:  FaceFusion stack (inswapper_128, GFPGAN, ArcFace)
# Use:    Face swapping, face enhancement, identity transfer.
# Note:   FaceFusion requires its own model set — see workflows/comfyui/facefusion/README.md

COMFYUI_MODEL=inswapper_128.onnx
COMFYUI_MODEL_PATH=/models/face/facefusion
COMFYUI_EXTRA_MODEL_PATHS=/models/upscalers/gfpgan:/models/face
COMFYUI_PREVIEW_METHOD=auto
COMFYUI_LISTEN=0.0.0.0
COMFYUI_PORT=8188
