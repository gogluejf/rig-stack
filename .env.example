# rig-stack environment configuration
# Copy this file to .env and adjust to your setup.
# .env is gitignored — never commit secrets.
#
# IMPORTANT: The three path variables below are the only ones you MUST change
# if your server layout differs from the reference setup (/data, /models, /docker).

# ── Host layout ────────────────────────────────────────────────────────────────
# Root paths on the host machine. All container bind mounts derive from these.
MODELS_ROOT=/models
DATA_ROOT=/data
DOCKER_ROOT=/docker

# ── Hardware ───────────────────────────────────────────────────────────────────
# GPU and OS are auto-detected at runtime — no need to set them here.
# CUDA_VERSION: host-side CUDA version; edge containers pin their own
CUDA_VERSION=12.8

# ── Traefik ────────────────────────────────────────────────────────────────────
TRAEFIK_PORT=80
TRAEFIK_TLS_PORT=443
TRAEFIK_DASHBOARD_PORT=8080

# ── vLLM ──────────────────────────────────────────────────────────────────────
VLLM_PORT=8000

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_PORT=6333

# Generate strong random values for production:
#   openssl rand -hex 32
LANGFUSE_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
LANGFUSE_SALT=changeme-generate-with-openssl-rand-hex-32
NEXTAUTH_SECRET=changeme-generate-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3000

# ── Postgres (Langfuse only) ───────────────────────────────────────────────────
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=changeme
POSTGRES_DB=langfuse
DATABASE_URL=postgresql://langfuse:changeme@postgres:5432/langfuse

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required for gated models (Llama, some Qwen variants).
# Get your token at https://huggingface.co/settings/tokens
HF_TOKEN=
